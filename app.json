{
  "expo": {
    "name": "VOLTLINE",
    "slug": "voltline",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#030310",
    "splash": {
      "backgroundColor": "#030310"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chancewde.voltline"
    },
    "android": {
      "package": "com.chancewde.voltline",
      "adaptiveIcon": {
        "backgroundColor": "#030310"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
